# Artastic Web Services — Environment Configuration
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# SMTP Configuration
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=ssl
SMTP_USER=your-email@artasticwebservices.com
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=your-email@artasticwebservices.com
SMTP_FROM_NAME=Artastic Web Services
MAIL_TO=admin@artasticwebservices.com

# Admin panel password (protects /mailer-admin-aws7749)
SMTP_ADMIN_PASS=your-admin-panel-password

# Debug mode — keep false in production
SMTP_DEBUG=false

# Environment
APP_ENV=production

# Local dev override — set true to write emails to logs/mail-dev.log instead of sending
SMTP_LOCAL_DEV=false

# Mailer admin panel IP allowlist — comma-separated (localhost is always allowed)
# Add your home/office public IP so https://yoursite.com/mailer-admin-aws7749 works
ADMIN_ALLOWED_IPS=
