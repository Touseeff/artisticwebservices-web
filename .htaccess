# ArtisticWebServices - Apache Configuration
# Performance + SEO + Security + Clean URLs
# Updated: 2026-04-05

Options -Indexes
ServerSignature Off

# ─── Charset ────────────────────────────────────────
AddDefaultCharset UTF-8

# ─── Compression (GZip) ─────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml
    AddOutputFilterByType DEFLATE font/woff font/woff2 application/x-font-woff
</IfModule>

# ─── Browser Caching ────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/webp         "access plus 1 year"
    ExpiresByType image/png          "access plus 1 year"
    ExpiresByType image/jpg          "access plus 1 year"
    ExpiresByType image/jpeg         "access plus 1 year"
    ExpiresByType image/gif          "access plus 1 year"
    ExpiresByType image/svg+xml      "access plus 1 year"
    ExpiresByType image/x-icon       "access plus 1 year"
    ExpiresByType text/css           "access plus 1 month"
    ExpiresByType text/javascript    "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType application/x-font-woff "access plus 1 year"
    ExpiresByType font/woff          "access plus 1 year"
    ExpiresByType font/woff2         "access plus 1 year"
    ExpiresByType video/mp4          "access plus 1 month"
</IfModule>

# ─── Security Headers ────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "camera=(), microphone=(), geolocation=(self), payment=()"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://embed.tawk.to https://va.tawk.to https://cdn.tawk.to; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com data:; img-src 'self' data: https:; connect-src 'self' https://artisticwebservices.com https://va.tawk.to wss://*.tawk.to; frame-src https://embed.tawk.to; object-src 'none'; base-uri 'self';"
    # Cache control for static assets
    <FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico|woff|woff2|css|js)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# ─── Rewrite Rules ──────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    # Production domain root
    RewriteBase /

    # Force HTTPS
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Force non-www to www (uncomment if using www as canonical)
    # RewriteCond %{HTTP_HOST} !^www\. [NC]
    # RewriteRule ^ https://www.%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Redirect .html to clean URL (301 permanent)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^(.+)\.html$ /$1 [R=301,L]

    # Redirect /index or /index.php to root /
    RewriteRule ^index\.php$ / [R=301,L]
    RewriteRule ^index$ / [R=301,L]

    # Redirect any .php URL to its clean equivalent (strip .php)
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{THE_REQUEST} \s/+(.+)\.php[\s?] [NC]
    RewriteRule ^ /%1 [R=301,L]

    # Clean URLs: internally serve .php for extension-less requests
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME}\.php -f
    RewriteRule ^([^\.]+)$ $1.php [NC,L]

    # Default index
    DirectoryIndex index.php index.html

    # Block access to sensitive files and directories
    RewriteRule ^(includes|prompt|vendor)/.*$ - [F,L]
    RewriteRule ^convert_to_php\.py$ - [F,L]
    RewriteRule ^cleanup_tracking\.py$ - [F,L]
    RewriteRule ^generate_sitemap\.py$ - [F,L]
    RewriteRule ^\.env$ - [F,L]
    RewriteRule ^composer\.(json|lock)$ - [F,L]
</IfModule>

# ─── Custom Error Pages ──────────────────────────────
ErrorDocument 404 /index.php
ErrorDocument 403 /index.php
ErrorDocument 500 /index.php
